generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String     @id @default(auto()) @map("_id") @db.ObjectId
  firstName         String
  lastName          String
  email             String     @unique
  password          String?
  profileView       Int        @default(0)
  image             String?
  isEmailVerified   Boolean    @default(false)
  isVerified        Boolean    @default(false)
  role              Role       @default(USER)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  status            UserStatus @default(ACTIVE)
  passwordChangedAt DateTime?
  fcmToken          String?
  accountWith       String?
  isDeleted         Boolean    @default(false)

  otps OTP[]

  @@map("users")
}

model OTP {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  otpCode   String
  expiry    DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otps")
}

enum Role {
  SUPERADMIN
  ADMIN
  USER
}

enum UserStatus {
  PENDING
  ACTIVE
  INACTIVE
  BLOCKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Customer {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  fullName    String
  phoneNumber String   @unique
  password    String?
  email       String?
  totalOrders Int      @default(0)
  totalSpent  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]

  @@map("customers")
}

model Order {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber   String      @unique
  customerId    String?     @db.ObjectId
  fullName      String
  phoneNumber   String
  city          String
  thanaUpazila  String?
  address       String
  productName   String
  productPrice  Float
  originalPrice Float?
  quantity      Int
  discount      Float       @default(0)
  deliveryFee   Float       @default(0)
  subtotal      Float
  total         Float
  status        OrderStatus @default(PENDING)
  statusNote    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  shipment Shipment?

  @@index([customerId])
  @@index([phoneNumber])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Shipment {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  orderId           String    @unique @db.ObjectId
  provider          String    @default("STEADFAST")
  consignmentId     String?   @unique
  trackingCode      String?
  invoice           String    @unique
  recipientName     String
  recipientPhone    String
  alternativePhone  String?
  recipientEmail    String?
  recipientAddress  String
  codAmount         Float
  deliveryCharge    Float?
  deliveryStatus    String    @default("in_review")
  trackingMessage   String?
  note              String?
  itemDescription   String?
  totalLot          Int?
  deliveryType      Int       @default(0)
  assignedToName    String?
  assignedToPhone   String?
  assignedToHub     String?
  internalNote      String?
  lastUpdatedAt     DateTime?
  providerPayload   Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  order         Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierEvents CourierEvent[]

  @@index([trackingCode])
  @@index([deliveryStatus])
  @@map("shipments")
}

model CourierEvent {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  shipmentId         String   @db.ObjectId
  notificationType   String
  status             String?
  trackingMessage    String?
  codAmount          Float?
  deliveryCharge     Float?
  updatedAt          DateTime?
  rawPayload         Json
  createdAt          DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
  @@index([notificationType])
  @@map("courier_events")
}

model CourierBalanceSnapshot {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  provider       String   @default("STEADFAST")
  currentBalance Float
  rawPayload     Json?
  fetchedAt      DateTime @default(now())

  @@index([provider])
  @@map("courier_balance_snapshots")
}

model WithdrawalRequest {
  id        String            @id @default(auto()) @map("_id") @db.ObjectId
  provider  String            @default("STEADFAST")
  amount    Float
  status    WithdrawalStatus  @default(REQUESTED)
  note      String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@index([status])
  @@map("withdrawal_requests")
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  REJECTED
}